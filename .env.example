# Google Keep Credentials (Optional)
# 取得方法: https://myaccount.google.com/apppasswords でアプリパスワードを発行してください
KEEP_USERNAME="your_email@gmail.com"
KEEP_PASSWORD="your-app-password"

# Gemini API Key (Required)
# 取得方法: https://aistudio.google.com/ にアクセスし、「Get API key」から作成してください
GEMINI_API_KEY="AIza..."

# Gemini Model (Optional)
# デフォルトは常に最新のProモデルを指す 'gemini-pro-latest' です。
# 別のモデル（gemini-2.5-flashなど）を使用したい場合はコメントアウトを外して変更してください。
# GEMINI_MODEL="gemini-pro-latest"
